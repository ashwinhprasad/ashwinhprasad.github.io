---
import BlogLayout from '../layouts/BlogLayout.astro';
import '../styles/global.css';
---

<BlogLayout title="Ashwin H Prasad | Personal Blog">
  <div class="about">
    <div class="bio">
      <p>
        I'm Ashwin, a software engineer at <a href="https://www.zoho.com/">Zoho</a>. 
      </p>
      <p>
        I'm into all things computer science, but lately I’ve been especially drawn to database engineering and reinforcement learning. 
        I use this blog to share thoughts on whatever engineering concept that intrigues me.
      </p>
      <p>
        This blog also doubles as my note-taking system, since my memory isn’t the best. 
        If you find something useful here, that’s a win for both of us.
      </p>
    </div>
    
    <div class="links">
      <ul>
        <li>Github: <a href="https://github.com/ashwinhprasad" target="_blank" rel="noopener noreferrer">ashwinhprasad</a></li>
        <li>Mail: ashwinprasad202@gmail.com</li>
        <li>LinkedIn: <a href="https://www.linkedin.com/in/ashwin-prasad-aa53441a7/" target="_blank" rel="noopener noreferrer">Ashwin Prasad H</a></li>
      </ul>
    </div>
  </div>
</BlogLayout>

<style>
  .about {
    max-width: 650px;
    margin: 0 auto;
  }
  
  h1 {
    font-size: 2.2rem;
    margin-bottom: 1.5rem;
  }
  
  .bio {
    margin-bottom: 2rem;
  }
  
  .links {
    margin-bottom: 2.5rem;
  }

  a {
    color: #000000;
    text-decoration: underline;
  }
  
  .links h2 {
    /* font-size: 1.3rem; */
    margin-bottom: 0.8rem;
  }
  
  .links ul {
    list-style:none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
</style>
