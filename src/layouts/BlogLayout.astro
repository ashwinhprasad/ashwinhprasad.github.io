---
import Navbar from '../components/Navbar.astro';

interface Props {
  title?: string;
}

const { title = "Ashwin H Prasad" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="navbar-container">
      <Navbar />
    </div>
    
    <div class="container">
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --background-color: #fafafa;
    --text-color: #333;
  }
  
  html {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    background-color: var(--background-color);
    color: var(--text-color);
  }
  
  body {
    margin: 0;
    padding: 0;
    line-height: 1.6;
  }
  
  .navbar-container{
    max-width: 800px;
    margin: 0 auto;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
  }
  
  h1, h2, h3, h4, h5, h6 {
    margin: 1rem 0 0.5rem;
    font-weight: 600;
    line-height: 1.3;
  }
  
  a {
    color: #3245ff;
  }
  
  img {
    max-width: 100%;
    height: auto;
  }
</style>